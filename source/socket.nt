import {
  core.c-int {c-int},
  core.file.descriptor {descriptor},
  core.system {system},
  this.address-family {address-family},
  this.socket-address {socket-address},
  this.socket-type {socket-type},
  this.socket._server {create-server-socket, run},
}

data config {
| Config(
    family: address-family,
    comm-type: socket-type,
    reuse-socket: bool,
    protocol: c-int,
    port: int16,
    address: &string,
    backlog: c-int,
    threads: int,
    interpreter: (socket-address, descriptor) -> string,
  )
}

inline start-server(c: config) -> system(unit) {
  let Config{family, comm-type, reuse-socket, protocol, address, port, backlog, interpreter, threads} = c;
  try s = create-server-socket(family, comm-type, reuse-socket, protocol, address, port, backlog);
  run(threads, s, interpreter)
}
